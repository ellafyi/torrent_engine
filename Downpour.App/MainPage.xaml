<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Downpour.App.ViewModels"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="Downpour.App.MainPage"
             x:DataType="vm:MainViewModel"
             Shell.NavBarIsVisible="False"
             Title="Downpour">

    <Grid RowDefinitions="32, 48, *">

        <!-- Custom Titlebar (Window Controls Area) -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto, *"
              Padding="12,0"
              BackgroundColor="Transparent">

            <!-- Title / Icon -->
            <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                <mi:MauiIcon Icon="{mi:Fluent WeatherRain24}" IconSize="16" IconColor="{AppThemeBinding Light=#512BD4, Dark=#A482FF}" />
                <Label Text="Downpour"
                       FontAttributes="Bold"
                       FontSize="12"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Grid>

        <!-- Ribbon Toolbar -->
        <Grid Grid.Row="1"
              ColumnDefinitions="Auto, *, Auto"
              Padding="12,0"
              BackgroundColor="{AppThemeBinding Light=#08000000, Dark=#1AFFFFFF}">

            <!-- Action Buttons -->
            <HorizontalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                
                <ImageButton Command="{Binding AddTorrentCommand}"
                             Source="{mi:Fluent Add24}"
                             WidthRequest="36"
                             HeightRequest="36"
                             Padding="6"
                             BackgroundColor="Transparent"
                             ToolTipProperties.Text="Add Torrent" />

                <ImageButton Command="{Binding PauseTorrentCommand}"
                             IsEnabled="{Binding SelectedTorrent.CanPause, FallbackValue=False}"
                             Source="{mi:Fluent Pause24}"
                             WidthRequest="36"
                             HeightRequest="36"
                             Padding="6"
                             BackgroundColor="Transparent"
                             ToolTipProperties.Text="Pause" />

                <ImageButton Command="{Binding ResumeTorrentCommand}"
                             IsEnabled="{Binding SelectedTorrent.CanResume, FallbackValue=False}"
                             Source="{mi:Fluent Play24}"
                             WidthRequest="36"
                             HeightRequest="36"
                             Padding="6"
                             BackgroundColor="Transparent"
                             ToolTipProperties.Text="Resume" />

                <ImageButton Command="{Binding RemoveTorrentCommand}"
                             IsEnabled="{Binding HasSelection}"
                             Source="{mi:Fluent Delete24}"
                             WidthRequest="36"
                             HeightRequest="36"
                             Padding="6"
                             BackgroundColor="Transparent"
                             ToolTipProperties.Text="Remove" />

                <ImageButton Command="{Binding RemoveAndDeleteCommand}"
                             IsEnabled="{Binding HasSelection}"
                             Source="{mi:Fluent DeleteDismiss24}"
                             WidthRequest="36"
                             HeightRequest="36"
                             Padding="6"
                             BackgroundColor="Transparent"
                             ToolTipProperties.Text="Delete Files" />

                <BoxView WidthRequest="1" HeightRequest="16" Color="Gray" Margin="6,0" Opacity="0.5"/>

                <ImageButton Command="{Binding ClearDatabaseCommand}"
                             Source="{mi:Fluent DatabaseArrowDown20}"
                             WidthRequest="36"
                             HeightRequest="36"
                             Padding="6"
                             BackgroundColor="Transparent"
                             ToolTipProperties.Text="Clear DB" />

            </HorizontalStackLayout>

            <!-- Center Global Speeds -->
            <HorizontalStackLayout Grid.Column="1"
                                   Spacing="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                <Label Text="{Binding GlobalDownloadSpeed}"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#2E8B57, Dark=#81C784}" />
                <Label Text="{Binding GlobalUploadSpeed}"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#1565C0, Dark=#64B5F6}" />
            </HorizontalStackLayout>
        </Grid>

        <!-- Torrent list -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Torrents}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedTorrent, Mode=TwoWay}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:TorrentItemViewModel">
                    <VerticalStackLayout Padding="14,10" Spacing="5">

                        <!-- Name + status -->
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0"
                                   Text="{Binding Name}"
                                   FontAttributes="Bold"
                                   FontSize="14"
                                   LineBreakMode="TailTruncation" />
                            <Label Grid.Column="1"
                                   Text="{Binding StatusLabel}"
                                   FontSize="12"
                                   VerticalOptions="Center"
                                   Margin="8,0,0,0" />
                        </Grid>

                        <!-- Progress bar -->
                        <ProgressBar Progress="{Binding ProgressFraction}"
                                     HeightRequest="6" />

                        <!-- Size / speeds / peers -->
                        <Grid ColumnDefinitions="2*, *, *, *">
                            <Label Grid.Column="0"
                                   Text="{Binding SizeText}"
                                   FontSize="11" />
                            <Label Grid.Column="1"
                                   Text="{Binding DownloadSpeed}"
                                   FontSize="11" />
                            <Label Grid.Column="2"
                                   Text="{Binding UploadSpeed}"
                                   FontSize="11" />
                            <Label Grid.Column="3"
                                   Text="{Binding PeerCountText}"
                                   FontSize="11"
                                   HorizontalOptions="End" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"
                                 Margin="0,2,0,0" />

                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <Label Text="No torrents added yet. Click '+ Add' to get started."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Margin="0,60,0,0"
                       FontSize="14" />
            </CollectionView.EmptyView>

        </CollectionView>

    </Grid>

</ContentPage>
