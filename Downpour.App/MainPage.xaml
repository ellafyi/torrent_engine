<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Downpour.App.ViewModels"
             xmlns:controls="clr-namespace:Downpour.App.Controls"
             x:Class="Downpour.App.MainPage"
             x:DataType="vm:MainViewModel"
             Shell.NavBarIsVisible="False"
             Title="Downpour"
             BackgroundColor="Transparent">

    <Grid RowDefinitions="Auto, Auto, *">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnBackgroundTapped" />
        </Grid.GestureRecognizers>

        <!-- Toolbar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *" VerticalOptions="Center" Margin="8,8,8,8">
            <HorizontalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                <Button x:Name="BtnAdd"
                        Text="Add"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding AddTorrentCommand}" />

                <Button x:Name="BtnPause"
                        Text="Pause"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding PauseTorrentCommand}"
                        IsEnabled="{Binding SelectedTorrent.CanPause, FallbackValue=False}" />

                <Button x:Name="BtnResume"
                        Text="Resume"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding ResumeTorrentCommand}"
                        IsEnabled="{Binding SelectedTorrent.CanResume, FallbackValue=False}" />

                <Button x:Name="BtnRemove"
                        Text="Remove"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding RemoveTorrentCommand}"
                        IsEnabled="{Binding HasSelection}" />

                <Button x:Name="BtnDelete"
                        Text="Delete"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding RemoveAndDeleteCommand}"
                        IsEnabled="{Binding HasSelection}" />

                <BoxView WidthRequest="1" HeightRequest="14" Color="Gray" Margin="4,0" Opacity="0.5" VerticalOptions="Center" />

                <Button x:Name="BtnClearDb"
                        Text="Clear DB"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding ClearDatabaseCommand}" />

                <BoxView WidthRequest="1" HeightRequest="14" Color="Gray" Margin="4,0" Opacity="0.5" VerticalOptions="Center" />

                <Button x:Name="BtnSettings"
                        Text="Settings"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding OpenSettingsCommand}" />

                <BoxView WidthRequest="1" HeightRequest="14" Color="Gray" Margin="4,0" Opacity="0.5" VerticalOptions="Center" />

                <Button x:Name="BtnDetails"
                        Text="Details"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding OpenDetailsCommand}"
                        IsEnabled="{Binding HasSelection}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="10" VerticalOptions="Center" Margin="0,0,4,0">
                <Label Text="{Binding ThrottleLimitText}"
                       IsVisible="{Binding HasThrottleLimits}"
                       FontSize="12"
                       Opacity="0.6"
                       VerticalOptions="Center" />
                <BoxView IsVisible="{Binding HasThrottleLimits}"
                         WidthRequest="1" HeightRequest="12" Color="Gray" Opacity="0.5" VerticalOptions="Center" />
                <Label Text="{Binding AllTimeStats}"
                       FontSize="11"
                       Opacity="0.6"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Grid>

        <!-- Global speed chart -->
        <controls:SpeedChartView Grid.Row="1"
                                 HeightRequest="52"
                                 Margin="8,0,8,4"
                                 DownloadSamples="{Binding GlobalDownloadHistory}"
                                 UploadSamples="{Binding GlobalUploadHistory}" />

        <!-- Torrent list -->
        <CollectionView x:Name="TorrentList"
                        Grid.Row="2"
                        BackgroundColor="Transparent"
                        ItemsSource="{Binding Torrents}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedTorrent, Mode=TwoWay}"
                        SelectionChanged="OnTorrentSelectionChanged">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:TorrentItemViewModel">
                    <Border Margin="8,3"
                            Padding="12,8"
                            BackgroundColor="{Binding CardBackgroundColor}"
                            Stroke="{AppThemeBinding Light=#1A000000, Dark=#1AFFFFFF}"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto, Auto, *, 2*, Auto, Auto"
                              ColumnSpacing="10"
                              VerticalOptions="Center">
                            <Label Grid.Column="0"
                                   Text="{Binding StatusLabel}"
                                   TextColor="{Binding StatusTextColor}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   MinimumWidthRequest="88"
                                   VerticalOptions="Center" />
                            <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Label Text="{Binding DownloadSpeed}" FontSize="11" VerticalOptions="Center" />
                                <Label Text="{Binding UploadSpeed}" FontSize="11" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Grid.Column="2"
                                   Text="{Binding Name}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation"
                                   VerticalOptions="Center" />
                            <ProgressBar Grid.Column="3"
                                         Progress="{Binding ProgressFraction}"
                                         HeightRequest="6"
                                         VerticalOptions="Center" />
                            <Label Grid.Column="4"
                                   Text="{Binding ProgressPercent}"
                                   FontSize="11"
                                   MinimumWidthRequest="34"
                                   HorizontalTextAlignment="End"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="5"
                                   Text="{Binding PeerCountText}"
                                   FontSize="11"
                                   MinimumWidthRequest="28"
                                   HorizontalTextAlignment="End"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <Label Text="No torrents added yet. Click '+ Add' to get started."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Margin="0,60,0,0"
                       FontSize="14" />
            </CollectionView.EmptyView>

        </CollectionView>

    </Grid>

</ContentPage>
