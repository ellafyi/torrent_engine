<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Downpour.App.ViewModels"
             x:Class="Downpour.App.MainPage"
             x:DataType="vm:MainViewModel"
             Shell.NavBarIsVisible="False"
             Title="Downpour"
             BackgroundColor="Transparent">

    <Grid RowDefinitions="Auto, *">

        <!-- Toolbar -->
        <HorizontalStackLayout Grid.Row="0" Spacing="4" VerticalOptions="Center" Margin="8,8,8,8">
            <Button x:Name="BtnAdd"
                    Text="Add"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding AddTorrentCommand}" />

            <Button x:Name="BtnPause"
                    Text="Pause"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding PauseTorrentCommand}"
                    IsEnabled="{Binding SelectedTorrent.CanPause, FallbackValue=False}" />

            <Button x:Name="BtnResume"
                    Text="Resume"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding ResumeTorrentCommand}"
                    IsEnabled="{Binding SelectedTorrent.CanResume, FallbackValue=False}" />

            <Button x:Name="BtnRemove"
                    Text="Remove"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding RemoveTorrentCommand}"
                    IsEnabled="{Binding HasSelection}" />

            <Button x:Name="BtnDelete"
                    Text="Delete"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding RemoveAndDeleteCommand}"
                    IsEnabled="{Binding HasSelection}" />

            <BoxView WidthRequest="1" HeightRequest="14" Color="Gray" Margin="4,0" Opacity="0.5" VerticalOptions="Center" />

            <Button x:Name="BtnClearDb"
                    Text="Clear DB"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding ClearDatabaseCommand}" />
        </HorizontalStackLayout>

        <!-- Torrent list -->
        <CollectionView Grid.Row="1"
                        BackgroundColor="Transparent"
                        ItemsSource="{Binding Torrents}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedTorrent, Mode=TwoWay}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:TorrentItemViewModel">
                    <Border Margin="8,3"
                            Padding="14,10"
                            BackgroundColor="{AppThemeBinding Light=#72FFFFFF, Dark=#12FFFFFF}"
                            Stroke="{AppThemeBinding Light=#1A000000, Dark=#1AFFFFFF}"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="5">

                            <!-- Name + status -->
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontAttributes="Bold"
                                       FontSize="14"
                                       LineBreakMode="TailTruncation" />
                                <Label Grid.Column="1"
                                       Text="{Binding StatusLabel}"
                                       FontSize="12"
                                       VerticalOptions="Center"
                                       Margin="8,0,0,0" />
                            </Grid>

                            <!-- Progress bar -->
                            <ProgressBar Progress="{Binding ProgressFraction}"
                                         HeightRequest="6" />

                            <!-- Size / speeds / peers -->
                            <Grid ColumnDefinitions="2*, *, *, *">
                                <Label Grid.Column="0"
                                       Text="{Binding SizeText}"
                                       FontSize="11" />
                                <Label Grid.Column="1"
                                       Text="{Binding DownloadSpeed}"
                                       FontSize="11" />
                                <Label Grid.Column="2"
                                       Text="{Binding UploadSpeed}"
                                       FontSize="11" />
                                <Label Grid.Column="3"
                                       Text="{Binding PeerCountText}"
                                       FontSize="11"
                                       HorizontalOptions="End" />
                            </Grid>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <Label Text="No torrents added yet. Click '+ Add' to get started."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Margin="0,60,0,0"
                       FontSize="14" />
            </CollectionView.EmptyView>

        </CollectionView>

    </Grid>

</ContentPage>
