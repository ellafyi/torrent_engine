<maui:MauiWinUIApplication
    x:Class="Downpour.App.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:maui="using:Microsoft.Maui"
    xmlns:local="using:Downpour.App.WinUI">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>

                <ResourceDictionary x:Key="Light">
                    <!-- Transparent page background so Mica shows through all layers -->
                    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="Transparent"/>
                    <!-- Subtle flat button style with hover/press/disabled states -->
                    <SolidColorBrush x:Key="ButtonBackground"               Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"    Color="#12000000"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed"        Color="#1C000000"/>
                    <SolidColorBrush x:Key="ButtonBackgroundDisabled"       Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonForeground"               Color="#1A1A1A"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver"    Color="#1A1A1A"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed"        Color="#000000"/>
                    <SolidColorBrush x:Key="ButtonForegroundDisabled"       Color="#72000000"/>
                    <SolidColorBrush x:Key="ButtonBorderBrush"              Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver"   Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed"       Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushDisabled"      Color="Transparent"/>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackground"               Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"    Color="#12FFFFFF"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed"        Color="#1CFFFFFF"/>
                    <SolidColorBrush x:Key="ButtonBackgroundDisabled"       Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonForeground"               Color="#F0F0F0"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver"    Color="#F0F0F0"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed"        Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="ButtonForegroundDisabled"       Color="#72FFFFFF"/>
                    <SolidColorBrush x:Key="ButtonBorderBrush"              Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver"   Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed"       Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushDisabled"      Color="Transparent"/>
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</maui:MauiWinUIApplication>
