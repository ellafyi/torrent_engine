<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Downpour.App.ViewModels"
             xmlns:controls="clr-namespace:Downpour.App.Controls"
             x:Class="Downpour.App.Views.TorrentDetailsPage"
             x:DataType="vm:TorrentDetailsViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#80000000">

    <Border MaximumWidthRequest="520"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Padding="24"
            BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#2D2D2D}"
            Stroke="{AppThemeBinding Light=#1A000000, Dark=#1AFFFFFF}"
            StrokeThickness="1">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="8" />
        </Border.StrokeShape>

        <VerticalStackLayout Spacing="16">

            <!-- Title -->
            <Label Text="{Binding Item.Name}"
                   FontSize="16"
                   FontAttributes="Bold"
                   LineBreakMode="TailTruncation" />

            <!-- Status + peer count row -->
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                <Label Grid.Column="0"
                       Text="{Binding Item.StatusLabel}"
                       TextColor="{Binding Item.StatusTextColor}"
                       FontSize="12"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
                <Label Grid.Column="2"
                       Text="{Binding Item.PeerCountText}"
                       FontSize="12"
                       Opacity="0.7"
                       VerticalOptions="Center" />
            </Grid>

            <!-- Progress bar + percent -->
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                <ProgressBar Grid.Column="0"
                             Progress="{Binding Item.ProgressFraction}"
                             HeightRequest="6"
                             VerticalOptions="Center" />
                <Label Grid.Column="1"
                       Text="{Binding Item.ProgressPercent}"
                       FontSize="12"
                       MinimumWidthRequest="38"
                       HorizontalTextAlignment="End"
                       VerticalOptions="Center" />
            </Grid>

            <!-- Size -->
            <Label Text="{Binding Item.SizeText}"
                   FontSize="12"
                   Opacity="0.7" />

            <!-- Speeds -->
            <HorizontalStackLayout Spacing="16">
                <Label Text="{Binding Item.DownloadSpeed}"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light=#2E8B57, Dark=#81C784}" />
                <Label Text="{Binding Item.UploadSpeed}"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light=#1565C0, Dark=#64B5F6}" />
            </HorizontalStackLayout>

            <!-- Speed graph -->
            <controls:SpeedChartView HeightRequest="80"
                                     DownloadSamples="{Binding DownloadHistory}"
                                     UploadSamples="{Binding UploadHistory}" />

            <!-- Close -->
            <Button Text="Close"
                    HorizontalOptions="End"
                    Command="{Binding CloseCommand}"
                    Style="{StaticResource FlatButton}" />

        </VerticalStackLayout>
    </Border>

</ContentPage>
