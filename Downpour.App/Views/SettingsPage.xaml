<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Downpour.App.ViewModels"
             x:Class="Downpour.App.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#80000000"
             Title="Settings">

    <Grid VerticalOptions="Center" HorizontalOptions="Center" Padding="40">
        <Border WidthRequest="420"
                Padding="28"
                HorizontalOptions="Center"
                BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#2D2D2D}"
                Stroke="{AppThemeBinding Light=#1A000000, Dark=#1AFFFFFF}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8">

            <VerticalStackLayout Spacing="16">

                <Label Text="Settings"
                       FontSize="20"
                       FontAttributes="Bold"
                       Margin="0,0,0,4" />

                <!-- Listen port -->
                <Label Text="Listen port" FontAttributes="Bold" FontSize="13" />
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                    <Entry Grid.Column="0"
                           Text="{Binding ListenPortText}"
                           Keyboard="Numeric"
                           Placeholder="1–65535" />
                </Grid>

                <!-- Seeding -->
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                    <Label Grid.Column="0"
                           Text="Enable seeding after completion"
                           FontAttributes="Bold"
                           FontSize="13"
                           VerticalOptions="Center" />
                    <Switch Grid.Column="1"
                            IsToggled="{Binding SeedingEnabled}"
                            VerticalOptions="Center" />
                </Grid>

                <!-- Download speed -->
                <Label Text="Max download speed (KB/s — 0 for unlimited)" FontAttributes="Bold" FontSize="13" />
                <Entry Text="{Binding MaxDownloadKbpsText}"
                       Keyboard="Numeric"
                       Placeholder="0" />

                <!-- Upload speed -->
                <Label Text="Max upload speed (MB/s — 0 for unlimited)" FontAttributes="Bold" FontSize="13" />
                <Entry Text="{Binding MaxUploadMbpsText}"
                       Keyboard="Numeric"
                       Placeholder="0" />

                <!-- Action buttons -->
                <HorizontalStackLayout HorizontalOptions="End"
                                       Spacing="8"
                                       Margin="0,8,0,0">
                    <Button Text="Cancel"
                            Command="{Binding CancelDialogCommand}"
                            WidthRequest="90" />
                    <Button Text="Save"
                            Command="{Binding ConfirmCommand}"
                            WidthRequest="90" />
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
