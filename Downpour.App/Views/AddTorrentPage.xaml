<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Downpour.App.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:Class="Downpour.App.Views.AddTorrentPage"
             x:DataType="vm:AddTorrentViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#80000000"
             Title="Add Torrent">

    <Grid VerticalOptions="Center" HorizontalOptions="Center" Padding="40">
        <Border WidthRequest="500"
                Padding="24"
                HorizontalOptions="Center"
                BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#2D2D2D}"
                Stroke="{AppThemeBinding Light=#1A000000, Dark=#1AFFFFFF}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8">

            <VerticalStackLayout Spacing="16">

                <Label Text="Add Torrent"
                       FontSize="20"
                       FontAttributes="Bold"
                       Margin="0,0,0,4" />

                <!-- Torrent files header + browse button -->
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                    <Label Grid.Column="0"
                           Text="Torrent files"
                           FontAttributes="Bold"
                           FontSize="13"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="Browse..."
                            Command="{Binding BrowseTorrentFilesCommand}"
                            WidthRequest="90" />
                </Grid>

                <!-- File list -->
                <Border HeightRequest="110"
                        Padding="8,4"
                        BackgroundColor="{AppThemeBinding Light=#E4E4E4, Dark=#1E1E1E}"
                        Stroke="{AppThemeBinding Light=#20000000, Dark=#20FFFFFF}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 4">
                    <CollectionView ItemsSource="{Binding TorrentFileNames}">
                        <CollectionView.EmptyView>
                            <Label Text="No files selected"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   FontSize="13"
                                   Opacity="0.45" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="sys:String">
                                <Label Text="{Binding .}"
                                       FontSize="12"
                                       Margin="0,2"
                                       LineBreakMode="TailTruncation" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>

                <!-- Download folder -->
                <Label Text="Download to" FontAttributes="Bold" FontSize="13" />
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                    <Label Grid.Column="0"
                           Text="{Binding DownloadPath, TargetNullValue='No folder selected'}"
                           LineBreakMode="MiddleTruncation"
                           VerticalOptions="Center"
                           FontSize="13" />
                    <Button Grid.Column="1"
                            Text="Browse..."
                            Command="{Binding BrowseDownloadFolderCommand}"
                            WidthRequest="90" />
                </Grid>

                <!-- Action buttons -->
                <HorizontalStackLayout HorizontalOptions="End"
                                       Spacing="8"
                                       Margin="0,16,0,0">
                    <Button Text="Cancel"
                            Command="{Binding CancelDialogCommand}"
                            WidthRequest="90" />
                    <Button Text="{Binding ConfirmButtonText}"
                            Command="{Binding ConfirmCommand}"
                            WidthRequest="90" />
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
