<?xml version="1.0" encoding="UTF-8"?>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Accent -->
    <Color x:Key="Accent">#F59E0B</Color>
    <Color x:Key="AccentHover">#FBBF24</Color>
    <Color x:Key="AccentDim">#B9740A</Color>
    <Color x:Key="AccentSoft">#26F59E0B</Color><!-- ~14 % -->
    <Color x:Key="AccentGlow">#59F59E0B</Color><!-- ~35 % -->

    <!-- Win11 Mica-ish dark -->
    <Color x:Key="Bg0">#1A1A1A</Color>
    <Color x:Key="Bg1">#202020</Color>
    <Color x:Key="Bg2">#272727</Color>
    <Color x:Key="Bg3">#2D2D2D</Color>
    <Color x:Key="Bg4">#353535</Color>
    <Color x:Key="Bg5">#404040</Color>
    <Color x:Key="BgMica">#1F1F1F</Color>

    <!-- Dividers -->
    <Color x:Key="Line">#0FFFFFFF</Color>  <!-- 6 % white -->
    <Color x:Key="Line2">#19FFFFFF</Color> <!-- 10 % white -->
    <Color x:Key="Line3">#2EFFFFFF</Color> <!-- 18 % white -->

    <!-- Text hierarchy -->
    <Color x:Key="Fg0">#F3F3F3</Color>
    <Color x:Key="Fg1">#D0D0D0</Color>
    <Color x:Key="Fg2">#9E9E9E</Color>
    <Color x:Key="Fg3">#707070</Color>
    <Color x:Key="Fg4">#555555</Color>

    <!-- Status colours -->
    <Color x:Key="StatusDown">#4CC2FF</Color>
    <Color x:Key="StatusSeed">#6CCB5F</Color>
    <Color x:Key="StatusPause">#B0B0B0</Color>
    <Color x:Key="StatusQueue">#D0A0FF</Color>
    <Color x:Key="StatusStall">#FFB454</Color>
    <Color x:Key="StatusError">#FF6B6B</Color>
    <Color x:Key="StatusCheck">#6CDDE0</Color>
    <Color x:Key="StatusMeta">#FFD479</Color>

    <!-- default Styles.xaml -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Primary">#F59E0B</Color>
    <Color x:Key="PrimaryDark">#B9740A</Color>
    <Color x:Key="PrimaryDarkText">#1A1206</Color>
    <Color x:Key="Secondary">#272727</Color>
    <Color x:Key="SecondaryDarkText">#D0D0D0</Color>
    <Color x:Key="Tertiary">#353535</Color>
    <Color x:Key="OffBlack">#1F1F1F</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="Bg1Brush" Color="{StaticResource Bg1}" />
    <SolidColorBrush x:Key="Bg2Brush" Color="{StaticResource Bg2}" />
    <SolidColorBrush x:Key="Bg3Brush" Color="{StaticResource Bg3}" />
    <SolidColorBrush x:Key="Bg4Brush" Color="{StaticResource Bg4}" />
    <SolidColorBrush x:Key="LineBrush" Color="{StaticResource Line}" />
    <SolidColorBrush x:Key="Line2Brush" Color="{StaticResource Line2}" />
    <SolidColorBrush x:Key="Line3Brush" Color="{StaticResource Line3}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoft}" />

</ResourceDictionary>