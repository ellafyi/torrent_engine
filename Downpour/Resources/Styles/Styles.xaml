<?xml version="1.0" encoding="UTF-8"?>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Global defaults -->

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BackgroundColor" Value="{StaticResource Bg1}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Fg1}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Display,Segoe UI,sans-serif" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource Fg0}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Fg3}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="MinimumHeightRequest" Value="0" />
    </Style>

    <Style TargetType="Border">
        <Setter Property="StrokeThickness" Value="0" />
    </Style>

</ResourceDictionary>
